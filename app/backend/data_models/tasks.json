{
    "title": "tasks",
    "type": "object",
    "properties": {
        "id": {
            "type": "integer",
            "description": "Primary key, auto-increment"
        },
        "room_id": {
            "type": "integer",
            "description": "Foreign key to rooms"
        },
        "name": {
            "type": "string",
            "description": "Task name"
        },
        "is_completed": {
            "type": "boolean",
            "description": "Whether task is completed"
        },
        "sort_order": {
            "type": "integer",
            "description": "Sort order"
        },
        "checked_by": {
            "type": "string",
            "description": "Name of person who last checked/unchecked this task"
        },
        "checked_at": {
            "type": "string",
            "description": "Timestamp when task was last checked/unchecked"
        },
        "user_id": {
            "type": "string",
            "description": "User ID"
        }
    },
    "required": [
        "id",
        "room_id",
        "name",
        "user_id"
    ]
}