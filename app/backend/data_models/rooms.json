{
    "title": "rooms",
    "type": "object",
    "properties": {
        "id": {
            "type": "integer",
            "description": "Primary key, auto-increment"
        },
        "user_id": {
            "type": "string",
            "description": "User ID"
        },
        "floor_id": {
            "type": "integer",
            "description": "FK to floors"
        },
        "project_id": {
            "type": "integer",
            "description": "FK to projects"
        },
        "room_number": {
            "type": "string",
            "description": "Room number/label"
        },
        "status": {
            "type": "string",
            "description": "Room status: not_started, in_progress, ready_for_inspection, completed, blocked"
        },
        "phase": {
            "type": "string",
            "description": "Current workflow phase for floor board placement"
        },
        "assigned_worker": {
            "type": "string",
            "description": "Name of assigned worker"
        },
        "comment": {
            "type": "string",
            "description": "Comment field"
        },
        "blocked_reason": {
            "type": "string",
            "description": "Reason if room is blocked"
        },
        "is_locked": {
            "type": "boolean",
            "description": "When true, only admin and BAS (manager) can edit room data"
        },
        "phase_lock_overrides": {
            "type": "object",
            "description": "Per-phase worker locks: phase key -> true (locked for Montør/Lærling) or false (force open). Omitted keys use defaults: phases after room.phase locked; at or before room.phase open unless locked."
        },
        "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
        }
    },
    "required": [
        "id",
        "user_id",
        "floor_id",
        "project_id",
        "room_number"
    ]
}